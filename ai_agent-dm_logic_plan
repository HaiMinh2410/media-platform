### Module 2: State Manager

**File:** `src/application/ai-agent/state-manager.ts`

**Logic xác định Stage tự động:**

```typescript
function determineStage(profile: FanProfile): ConversationStage {
  if (profile.dayCount <= 30) return 'G1';
  if (profile.dayCount <= 60) return 'G2';
  return 'G3';
}

function shouldPromoteStage(profile: FanProfile): boolean {
  // Promote sớm nếu emotion_score cao
  if (profile.emotionScore >= 0.85 && profile.stage === 'G1') return true;
  if (profile.emotionScore >= 0.80 && profile.stage === 'G2') return true;
  return false;
}
```

**Logic xác định Risk Level:**

```typescript
function assessRisk(profile: FanProfile, lastMessages: Message[]): RiskLevel {
  const hasSensitiveRequest = lastMessages.some(m => 
    SENSITIVE_PATTERNS.test(m.content)
  );
  if (hasSensitiveRequest && profile.fanType === 'Drainer') return 'high';
  if (hasSensitiveRequest) return 'medium';
  return 'low';
}
```

