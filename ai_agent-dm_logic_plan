  message_count     INT DEFAULT 0,
  emotion_score     FLOAT DEFAULT 0.5,      -- 0.0 → 1.0
  emotion_trend     TEXT DEFAULT 'stable',  -- increasing | decreasing | stable
  flirt_level       INT DEFAULT 0,          -- 0 | 1 | 2 | 3
  risk_level        TEXT DEFAULT 'low',     -- low | medium | high
  purchase_history  JSONB DEFAULT '[]',
  objections_seen   TEXT[] DEFAULT '{}',
  key_insights      TEXT[] DEFAULT '{}',
  next_action       TEXT DEFAULT 'continue',-- continue | send_link | exit | wait | escalate
  notes             TEXT,
  last_summary      JSONB,                  -- Long Context Summary cache
  link_sent_count   INT DEFAULT 0,
  last_link_sent_at TIMESTAMPTZ,
  created_at        TIMESTAMPTZ DEFAULT NOW(),
  updated_at        TIMESTAMPTZ DEFAULT NOW()
);
```

