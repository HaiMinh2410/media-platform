generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

model Workspace {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  slug                String              @unique
  settings            Json?               @default("{}")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  account_groups      AccountGroup[]
  customer_identities CustomerIdentity[]
  invitations         invitations[]
  platformAccounts    PlatformAccount[]
  workspace_members   workspace_members[]

  @@map("workspaces")
  @@schema("public")
}

model PlatformAccount {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id             String                   @db.Uuid
  platform               String                   @db.VarChar(10)
  platform_user_id       String
  platform_user_name     String
  created_at             DateTime                 @default(now())
  workspaceId            String                   @map("workspace_id") @db.Uuid
  disconnected_at        DateTime?                @db.Timestamptz(6)
  metadata               Json?                    @default("{}")
  account_memberships    AccountGroupMembership[]
  ai_personas            AIPersona?
  analytics_snapshots    analytics_snapshots[]
  auto_reply_rules       AutoReplyRule[]
  bot_configurations     bot_configurations?
  conversations          Conversation[]
  meta_tokens            meta_tokens[]
  profiles               profiles                 @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  posts                  posts[]
  tiktok_token_refreshes tiktok_token_refreshes[]
  tiktok_tokens          tiktok_tokens?

  @@unique([platform, platform_user_id])
  @@index([workspaceId], map: "idx_platform_accounts_workspace_id")
  @@map("platform_accounts")
  @@schema("public")
}

model Conversation {
  id                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id                 String                    @db.Uuid
  platform_conversation_id   String
  lastMessageAt              DateTime                  @default(now()) @map("last_message_at")
  status                     String?                   @default("open")
  customer_avatar            String?
  customer_name              String?
  customer_username          String?
  customer_link              String?
  is_vip                     Boolean                   @default(false)
  /// Added in T073: Advanced Inbox Schema
  priority                   String?                   @default("medium")
  sentiment                  String?                   @default("neutral")
  lead_status                String?                   @default("new")
  phone                      String?
  email                      String?
  birthday                   DateTime?
  address                    String?
  city                       String?
  state                      String?
  zip_code                   String?
  /// Points to the primary/canonical conversation when this convo is a cross-channel duplicate (T077)
  canonical_conversation_id  String?                   @db.Uuid
  tags                       String[]                  @default([])
  platform_accounts          PlatformAccount           @relation(fields: [account_id], references: [id], onDelete: Cascade)
  customer_platform_mappings CustomerPlatformMapping[]
  messages                   Message[]
  notes                      ConversationNote[]

  @@unique([account_id, platform_conversation_id])
  @@map("conversations")
  @@schema("public")
}

model Message {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId      String       @map("conversation_id") @db.Uuid
  senderId            String       @map("sender_id")
  content             String
  platform_message_id String       @unique
  is_read             Boolean      @default(false)
  createdAt           DateTime     @default(now()) @map("created_at")
  senderType          String?      @default("user") @map("sender_type")
  is_delivered        Boolean      @default(false)
  aiReplyLogs         AIReplyLog[]
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@schema("public")
}

model AIReplyLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId  String   @map("message_id") @db.Uuid
  prompt     String
  response   String
  model      String
  created_at DateTime @default(now())
  status     String   @default("suggested")
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("ai_reply_logs")
  @@schema("public")
}

model ConversationNote {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  content        String
  authorId       String?      @map("author_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_notes")
  @@schema("public")
}

