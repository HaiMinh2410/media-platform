/// Cross-channel customer identity — links the same person across Facebook, Instagram, etc.
model CustomerIdentity {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspace_id          String                    @db.Uuid
  /// Primary external sender ID used as the canonical key for this identity
  canonical_external_id String
  customer_name         String?
  customer_avatar       String?
  created_at            DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  workspace             Workspace                 @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  platform_mappings     CustomerPlatformMapping[]

  @@unique([workspace_id, canonical_external_id])
  @@index([workspace_id])
  @@map("customer_identities")
  @@schema("public")
}

/// Maps a single (platform, externalSenderId) pair to a CustomerIdentity
model CustomerPlatformMapping {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identity_id        String           @db.Uuid
  platform           String           @db.VarChar(20)
  external_sender_id String
  conversation_id    String           @db.Uuid
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  conversation       Conversation     @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  identity           CustomerIdentity @relation(fields: [identity_id], references: [id], onDelete: Cascade)

  @@unique([platform, external_sender_id])
  @@index([identity_id])
  @@index([conversation_id])
  @@map("customer_platform_mappings")
  @@schema("public")
}

